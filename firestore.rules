rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function email() {
      return request.auth.token.email;
    }

    function isSuperAdmin() {
      return signedIn() && email() == "ahmadrzzaq14@gmail.com";
    }

    function allowedData() {
      return get(/databases/$(database)/documents/allowedEmails/$(email())).data;
    }

    function isAllowed() {
      return signedIn() && (
        exists(/databases/$(database)/documents/allowedEmails/$(email())) ||
        isSuperAdmin()
      );
    }

    function role() {
      return isSuperAdmin() ? "admin" : allowedData().role;
    }

    function isAdmin() {
      return isAllowed() && role() == "admin";
    }

    function isBendahara() {
      return isAllowed() && role() == "bendahara";
    }

    function isAdminOrBendahara() {
      return isAdmin() || isBendahara();
    }

    match /allowedEmails/{emailId} {
      allow read: if isAllowed();
      allow create, update, delete: if isAdmin() || isSuperAdmin();
    }

    match /profiles/{uid} {
      allow read: if isAllowed() && (request.auth.uid == uid || isAdmin());
      allow create, update: if isAllowed() && request.auth.uid == uid;
      allow delete: if false;
    }

    match /students/{studentId} {
      allow read: if isAllowed();
      allow create, update, delete: if isAdmin();
    }

    match /cash/{cashId} {
      allow read: if isAllowed();
      allow create, update, delete: if isAdminOrBendahara();
    }

    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAllowed();
      allow update, delete: if false;
    }

    match /submissions/{submissionId} {
      allow read: if isAdmin() || isAdminOrBendahara()
        || (isAllowed() && resource.data.studentEmail == email());

      allow create: if isAllowed()
        && request.resource.data.studentEmail == email()
        && request.resource.data.studentUid == request.auth.uid;

      allow update, delete: if isAdmin();
    }

    match /attendance/{date}/records/{recordId} {
      allow read: if isAllowed();

      allow create, update: if isAdmin()
        || (
          isAllowed()
          && request.resource.data.method == "qr_location"
          && request.resource.data.updatedByUid == request.auth.uid
          && request.resource.data.updatedByEmail == email()
        );

      allow delete: if isAdmin();
    }

    match /attendanceSessions/{sessionCode} {
      allow read: if isAllowed();
      allow create, update, delete: if isAdmin();
    }

    match /qrAttendanceLogs/{logId} {
      allow read: if isAdminOrBendahara();

      allow create: if isAllowed()
        && request.resource.data.studentEmail == email()
        && request.resource.data.studentUid == request.auth.uid;

      allow update, delete: if isAdmin();
    }

    match /qrStudentLocations/{locationId} {
      allow read: if isAdminOrBendahara();

      allow create, update: if isAllowed()
        && request.resource.data.studentEmail == email()
        && request.resource.data.studentUid == request.auth.uid;

      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
