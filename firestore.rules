rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    /*
      GANTI EMAIL INI.
      Harus sama dengan SUPER_ADMIN_EMAIL di index.html.
    */
    function isSuperAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email == "ahmadrzzaq14@gmail.com";
    }

    function signedIn() {
      return request.auth != null
        && request.auth.token.email_verified == true;
    }

    function allowedEmailDoc() {
      return get(/databases/$(database)/documents/allowedEmails/$(request.auth.token.email));
    }

    function isAllowed() {
      return signedIn()
        && exists(/databases/$(database)/documents/allowedEmails/$(request.auth.token.email))
        && allowedEmailDoc().data.status == "active";
    }

    function role() {
      return isSuperAdmin() ? "admin" : allowedEmailDoc().data.role;
    }

    function isAdmin() {
      return isSuperAdmin() || (isAllowed() && role() == "admin");
    }

    function isBendahara() {
      return isAllowed() && role() == "bendahara";
    }

    function isAdminOrBendahara() {
      return isAdmin() || isBendahara();
    }

    match /allowedEmails/{email} {
      allow get: if isAdmin() || (signedIn() && request.auth.token.email == email);
      allow list: if isAdmin();

      allow create, update: if isAdmin()
        && request.resource.data.email is string
        && request.resource.data.role in ["admin", "bendahara", "siswa"]
        && request.resource.data.status in ["active", "inactive"];

      allow delete: if isAdmin();
    }

    match /students/{studentId} {
      allow read: if isAllowed() || isSuperAdmin();

      allow create, update: if isAdmin()
        && request.resource.data.name is string
        && request.resource.data.number is number
        && request.resource.data.className is string;

      allow delete: if isAdmin();
    }

    match /attendance/{date}/records/{studentId} {
      allow read: if isAllowed() || isSuperAdmin();

      allow create, update: if isAdmin()
        && request.resource.data.studentId == studentId
        && request.resource.data.status in ["hadir", "izin", "sakit", "alfa"];

      allow delete: if isAdmin();
    }

    match /cashTransactions/{transactionId} {
      allow read: if isAllowed() || isSuperAdmin();

      allow create: if isAdminOrBendahara()
        && request.resource.data.type in ["income", "expense"]
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.note is string
        && request.resource.data.byUid == request.auth.uid
        && request.resource.data.byEmail == request.auth.token.email;

      allow update: if false;

      allow delete: if isAdminOrBendahara();
    }

    match /activityLogs/{logId} {
      allow read: if isAdminOrBendahara() || isSuperAdmin();

      allow create: if (isAllowed() || isSuperAdmin())
        && request.resource.data.byUid == request.auth.uid
        && request.resource.data.byEmail == request.auth.token.email
        && request.resource.data.action is string
        && request.resource.data.detail is string;

      allow update, delete: if false;
    }



    match /userProfiles/{uid} {
      allow read: if isAdmin()
        || ((isAllowed() || isSuperAdmin()) && request.auth.uid == uid);

      allow create, update: if (isAllowed() || isSuperAdmin())
        && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.displayName is string;

      allow delete: if isAdmin();
    }

    match /attendanceRequests/{requestId} {
      allow create: if isAllowed()
        && request.resource.data.studentEmail == request.auth.token.email
        && request.resource.data.studentUid == request.auth.uid
        && request.resource.data.status == "pending"
        && request.resource.data.type in ["izin", "sakit"]
        && request.resource.data.studentName is string
        && request.resource.data.reason is string
        && request.resource.data.proof is string
        && request.resource.data.date is string;

      allow read: if isAdmin()
        || (isAllowed() && resource.data.studentEmail == request.auth.token.email);

      allow update: if isAdmin()
        && request.resource.data.status in ["approved", "rejected", "pending"];

      allow delete: if isAdmin();
    }


    match /attendanceSessions/{sessionCode} {
      allow read: if isAllowed() || isSuperAdmin();

      allow create, update, delete: if isAdmin();
    }

    match /qrAttendanceLogs/{logId} {
      allow create: if isAllowed()
        && request.resource.data.studentEmail == request.auth.token.email
        && request.resource.data.studentUid == request.auth.uid;

      allow read: if isAdmin() || isAdminOrBendahara()
        || (isAllowed() && resource.data.studentEmail == request.auth.token.email);

      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
